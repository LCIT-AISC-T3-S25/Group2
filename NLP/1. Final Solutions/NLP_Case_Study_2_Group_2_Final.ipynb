   },
   "source": [
    "### Complete Pipeline"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
   "metadata": {
    "id": "iCJQRK_8P5W_"
   },
   "outputs": [],
   "source": [
    "def clean_pipeline(text):\n",
    "    text = process_emojis_symbols(text)\n",
    "    # text = extract_entities(text) Skipped due to excessive computational requirements\n",
    "    text = text.lower()\n",
    "    # text = correct_spelling(text) Skipped due to excessive computational requirements\n",
    "    text = expand_slangs(text)\n",
    "    text = remove_punctuations(text)\n",
    "    return text"
   ]
  },
