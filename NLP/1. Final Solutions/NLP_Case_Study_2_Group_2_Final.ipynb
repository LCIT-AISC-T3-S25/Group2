    "import torch\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import pickle\n",
    "import tensorflow as tf\n",
    "from lime.lime_text import LimeTextExplainer\n",
    "from sklearn.preprocessing import LabelEncoder\n",
    "\n",
    "# Load preprocessed data\n",
    "data_dir = \"C://PG AI and DS//Semester 3//processed_data/\"\n",
    "\n",
    "with open(os.path.join(data_dir, \"tokenizer.pkl\"), \"rb\") as f:\n",
    "    tokenizer = pickle.load(f)\n",
    "with open(os.path.join(data_dir, \"class_weights.pkl\"), \"rb\") as f:\n",
    "    class_weights = pickle.load(f)\n",
    "with open(os.path.join(data_dir, \"label_encoder.pkl\"), \"rb\") as f:\n",
    "    label_encoder = pickle.load(f)\n",
    "\n",
    "class_names = list(label_encoder.classes_)\n",
    "corpus_df= pd.read_csv(\"C://PG AI and DS//Semester 3//processed_data/Cleaned_Dataset.csv\")\n",
    "# ----------------------------\n",
    "# 💡 LIME Wrapper Class\n",
    "# ----------------------------\n",
    "class PredictWrapper:\n",
    "    def __init__(self, model, tokenizer, max_len, device):\n",
    "        self.model = model\n",
    "        self.tokenizer = tokenizer\n",
    "        self.max_len = max_len\n",
    "        self.device = device\n",
    "\n",
    "    def predict(self, texts):\n",
    "        # Convert input text to padded token IDs\n",
    "        sequences = self.tokenizer.texts_to_sequences(texts)\n",
    "        padded = tf.keras.preprocessing.sequence.pad_sequences(\n",
    "            sequences, maxlen=self.max_len, truncating='post'\n",
    "        )\n",
    "        inputs = torch.LongTensor(padded).to(self.device)\n",
    "\n",
    "        with torch.no_grad():\n",
    "            outputs = self.model(inputs)\n",
    "            probs = torch.softmax(outputs, dim=1).cpu().numpy()\n",
    "        return probs\n",
    "\n",
    "# ----------------------------\n",
    "# 🧪 Select Example Input\n",
    "# ----------------------------\n",
    "sample_index = 10  # pick any index from your dataset\n",
    "sample_text = corpus_df['Cleaned_Text'].iloc[sample_index]\n",
    "true_label = corpus_df['Sentiment_Merged'].iloc[sample_index]\n",
    "\n",
    "print(f\"\\n Sample Text:\\n\\\"{sample_text}\\\"\\nTrue Label: {true_label}\")\n",
    "\n",
    "# ----------------------------\n",
    "# 🔍 Run LIME\n",
    "# ----------------------------\n",
    "explainer = LimeTextExplainer(class_names=class_names)\n",
    "predict_fn = PredictWrapper(model, tokenizer, max_len=250, device=device)\n",
    "\n",
    "explanation = explainer.explain_instance(\n",
    "    sample_text, \n",
    "    predict_fn.predict, \n",
    "    num_features=10, \n",
    "    top_labels=1\n",
    ")\n",
    "\n",
    "# ----------------------------\n",
    "# 📊 Visualize Results\n",
    "# ----------------------------\n",
    "explanation.show_in_notebook(text=True)\n",
    "\n",
    "# Optional: print top important words\n",
    "print(\"\\nTop Contributing Words:\")\n",
    "for word, weight in explanation.as_list(label=explanation.top_labels[0]):\n",
    "    print(f\"{word}: {weight:.4f}\")"
   ]
